---
import { getCollection } from "astro:content";
import Section from "./Section.astro";
import Testimonial from "./speaking/Testimonial.astro";

const testimonials = await getCollection("testimonial");
const count = testimonials.length;
---

<Section
  hasYPadding={false}
  hasMaxWidth={false}
  classStr="py-16 md:py-20"
>
  <div class="mx-auto mb-10 max-w-6xl px-8 text-center">
    <p class="mb-3 text-xs uppercase tracking-[0.2em] text-brand">testimonials</p>
    <h2 class="text-3xl font-bold md:text-5xl">What people have to say</h2>
  </div>

  <div
    class="group relative w-full"
    data-testimonial-carousel
    tabindex="0"
    role="region"
    aria-roledescription="carousel"
    aria-label="Testimonials. Use arrow keys or previous and next buttons to browse."
  >
    <div class="embla relative z-0 mx-auto w-full max-w-5xl px-3 sm:px-6 md:px-8">
      <div class="embla__viewport overflow-hidden">
        <div class="embla__container flex touch-pan-y -ml-3 md:-ml-4">
          {
            testimonials.map((testimonial, idx) => (
              <div
                class:list={[
                  "embla__slide testimonial-slide min-w-0 shrink-0 grow-0 basis-[82%] pl-3 sm:basis-[68%] sm:pl-4 md:basis-[62%] lg:basis-[58%]",
                  idx === 0 ? "is-selected" : "",
                ]}
                id={`testimonial-slide-${idx}`}
                role="group"
                aria-roledescription="slide"
                aria-label={`${idx + 1} of ${count}`}
              >
                <Testimonial testimonial={testimonial} isShort={true} />
              </div>
            ))
          }
        </div>
      </div>
    </div>

    <button
      type="button"
      class="testimonial-carousel-nav-prev pointer-events-auto absolute left-1 top-1/2 z-50 flex h-9 w-9 -translate-y-1/2 items-center justify-center rounded-full border border-white/15 bg-bgDark/50 text-white/70 backdrop-blur-sm transition-all hover:border-brand/40 hover:bg-bgDark/70 hover:text-brand focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand md:left-3 opacity-60 group-hover:opacity-90"
      aria-label="Previous testimonial"
    >
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M15 18l-6-6 6-6" />
      </svg>
    </button>
    <button
      type="button"
      class="testimonial-carousel-nav-next pointer-events-auto absolute right-1 top-1/2 z-50 flex h-9 w-9 -translate-y-1/2 items-center justify-center rounded-full border border-white/15 bg-bgDark/50 text-white/70 backdrop-blur-sm transition-all hover:border-brand/40 hover:bg-bgDark/70 hover:text-brand focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand md:right-3 opacity-60 group-hover:opacity-90"
      aria-label="Next testimonial"
    >
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M9 18l6-6-6-6" />
      </svg>
    </button>
  </div>
</Section>

<style>
  .embla__slide {
    pointer-events: none;
  }

  .embla__slide > * {
    pointer-events: auto;
  }

  .testimonial-slide {
    transition: opacity 0.3s ease;
  }

  .testimonial-slide:not(.is-selected) {
    opacity: 0.72;
  }

  .testimonial-slide.is-selected {
    opacity: 1;
  }
</style>

<script>
  import EmblaCarousel from "embla-carousel";

  const roots = document.querySelectorAll("[data-testimonial-carousel]");

  roots.forEach((root) => {
    const emblaEl = root.querySelector(".embla");
    if (!emblaEl) return;

    const slideCount = emblaEl.querySelectorAll(".embla__slide").length;
    if (slideCount === 0) return;

    const embla = EmblaCarousel(emblaEl, {
      loop: slideCount > 1,
      align: "center",
      slidesToScroll: 1,
      container: ".embla__container",
      slides: ".embla__slide",
    });

    const prevBtn = root.querySelector(".testimonial-carousel-nav-prev");
    const nextBtn = root.querySelector(".testimonial-carousel-nav-next");
    const lastSnapIndex = Math.max(0, embla.scrollSnapList().length - 1);

    const scrollPrevWrapped = () => {
      if (embla.canScrollPrev()) {
        embla.scrollPrev();
      } else {
        embla.scrollTo(lastSnapIndex);
      }
    };

    const scrollNextWrapped = () => {
      if (embla.canScrollNext()) {
        embla.scrollNext();
      } else {
        embla.scrollTo(0);
      }
    };

    const syncSelected = () => {
      const i = embla.selectedScrollSnap();
      embla.slideNodes().forEach((slide, idx) => {
        slide.classList.toggle("is-selected", idx === i);
      });
      const selected = embla.slideNodes()[i];
      root.setAttribute("aria-activedescendant", selected?.id || "");
    };

    embla.on("select", syncSelected);
    syncSelected();

    prevBtn?.addEventListener("click", (e) => {
      e.preventDefault();
      e.stopPropagation();
      scrollPrevWrapped();
    });

    nextBtn?.addEventListener("click", (e) => {
      e.preventDefault();
      e.stopPropagation();
      scrollNextWrapped();
    });

    root.addEventListener("keydown", (e) => {
      if (!(e instanceof KeyboardEvent)) return;
      if (e.key === "ArrowLeft") {
        e.preventDefault();
        scrollPrevWrapped();
      } else if (e.key === "ArrowRight") {
        e.preventDefault();
        scrollNextWrapped();
      }
    });
  });
</script>
