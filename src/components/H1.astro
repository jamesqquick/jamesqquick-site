---

interface Props {
    text: string;
    ariaLabel?: string;
    classStr?: string;
}
const { text, ariaLabel, classStr } = Astro.props;
---

<h1 class={`heading-1 block ${classStr || ""}`} aria-label={ariaLabel || text}>
  {text}
</h1>

<style>
  .heading-1 {
    font-family: var(--font-display);
    color: var(--color-text);
    font-size: 2.25rem;
    line-height: 1.1;
    letter-spacing: -0.02em;
    font-weight: 700;
  }

  @media (min-width: 768px) {
    .heading-1 {
      font-size: 3rem;
    }
  }
</style>
