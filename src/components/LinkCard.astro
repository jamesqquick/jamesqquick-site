---
import { getFormattedDate } from "../utils/dates";

export interface Props {
  slug: string;
  title: string;
  date: Date;
  description?: string;
  btnText?: string;
  tag?: string;
  openInNewTab?: boolean;
  dateLabelPrefix?: string;
}

const { slug, date, title, tag, description, openInNewTab = false, dateLabelPrefix = "" } =
  Astro.props;
---

<a
  href={slug}
  class="card-shell block overflow-hidden"
  data-interactive
  target={openInNewTab ? "_blank" : undefined}
  rel={openInNewTab ? "noopener noreferrer" : undefined}
>
  {tag && <span class="card-chip mb-2 inline-flex">{tag}</span>}
  <p class="mb-1 card-date">{dateLabelPrefix}{getFormattedDate(date)}</p>
  <h3 class="card-title font-bold text-2xl mb-2">
    {title}
  </h3>
  {description && (
    <p class="card-description">{description}</p>
  )}
</a>

<style>
  .card-shell {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card);
    padding: 1rem;
    transition:
      transform var(--duration-normal) var(--ease-out),
      box-shadow var(--duration-normal) var(--ease-out),
      border-color var(--duration-fast) var(--ease-out);
    text-decoration: none;
  }

  .card-shell:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
    border-color: var(--color-accent);
  }

  .card-chip {
    font-size: 0.75rem;
    line-height: 1rem;
    font-weight: 600;
    border-radius: var(--radius-full);
    color: var(--color-text);
    background: var(--color-ai-subtle);
    border: 1px solid rgba(53, 207, 255, 0.35);
    padding: 0.25rem 0.625rem;
  }

  .card-date,
  .card-description {
    color: var(--color-text-muted);
  }

  .card-title {
    color: var(--color-text);
    font-family: var(--font-display);
    line-height: 1.2;
  }
</style>
