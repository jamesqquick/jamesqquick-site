---
export interface Props {
  id: string;
  openFile?: string;
  height?: string;
}

const { id, openFile, height = "500px" } = Astro.props as Props;
const fileParam = openFile ? `&file=${encodeURIComponent(openFile)}` : "";
const src = `https://stackblitz.com/edit/${id}?embed=1${fileParam}`;
---

<div class="not-prose my-6 overflow-hidden rounded-xl border border-gray-700">
  <iframe
    src={src}
    title={`StackBlitz project: ${id}`}
    style={`width: 100%; height: ${height}; border: 0;`}
    loading="lazy"
    allow="cross-origin-isolated"
  />
  <noscript>
    <p class="p-3 text-sm text-gray-300">
      JavaScript is required to load the StackBlitz embed.
      <a class="text-brand hover:underline" href={`https://stackblitz.com/edit/${id}`}>Open in StackBlitz</a>.
    </p>
  </noscript>
</div>
