---
export interface Props {
  /** Object key in the bucket, e.g. `lessons/intro-video.mp4` */
  videoKey: string;
}

const { videoKey } = Astro.props;
const videoUrl = `/api/video/${videoKey}`;
---

<div class="video-container">
  <video controls width="100%" playsinline preload="metadata">
    <source src={videoUrl} type="video/mp4" />
    Your browser does not support the video tag.
  </video>
</div>

<style>
  .video-container {
    max-width: 800px;
    margin: auto;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1);
  }
</style>
