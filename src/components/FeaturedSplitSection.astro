---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import Link from "./Link.astro";
import SplitSection from "./SplitSection.astro";

type ImageLike = { src: string; width: number; height: number; format?: string };

export interface Props {
  /** Processed image from collections or site-root URL under `public/` */
  image: ImageLike | string;
  title: string;
  description: string;
  href: string;
  date: Date;
  /** When true, shows the fancy CTA link (default label is blog-oriented). */
  showCta?: boolean;
  /** Label for the fancy CTA; defaults to “Read blog” for blog featured surfaces. */
  ctaText?: string;
  /** Open image + title links in a new tab (e.g. external course URLs). */
  openInNewTab?: boolean;
}

const {
  image,
  title,
  description,
  href,
  date,
  showCta = true,
  ctaText = "Read blog",
  openInNewTab = false,
} = Astro.props as Props;

const externalRel = openInNewTab ? "noopener noreferrer" : undefined;
const coverIsPublicUrl = typeof image === "string" && image.startsWith("/");
---

<SplitSection contentClassStr="featured-shell">
  <a
    href={href}
    slot="left"
    target={openInNewTab ? "_blank" : undefined}
    rel={externalRel}
  >
    {
      coverIsPublicUrl ? (
        <img
          src={image as string}
          alt={title}
          class="featured-image h-auto w-full"
          loading="eager"
          decoding="async"
        />
      ) : (
        <Image
          height={540}
          width={960}
          src={image as ImageMetadata}
          class="featured-image"
          alt={title}
        />
      )
    }
  </a>
  <div slot="right" class="featured-content" data-interactive>
    <p class="featured-kicker text-lg uppercase">Featured</p>
    <a
      href={href}
      class="featured-title-link"
      target={openInNewTab ? "_blank" : undefined}
      rel={externalRel}
    >
      <h2 class="featured-title text-3xl font-bold mb-1">{title}</h2>
    </a>
    <p class="featured-description text-lg mb-4">
      {description}
    </p>
    <div
      class:list={[
        "flex items-center gap-4",
        showCta ? "justify-between" : "justify-end",
      ]}
    >
      {
        showCta ? (
          <Link isFancy={true} href={href} text={ctaText} />
        ) : null
      }
      <p class="featured-date text-lg">
        {date.toLocaleDateString("en-us", {
          year: "numeric",
          month: "short",
          day: "numeric",
        })}
      </p>
    </div>
  </div>
</SplitSection>

<style>
  .featured-shell {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-hero);
    overflow: hidden;
    padding: 1rem;
    background: color-mix(in srgb, var(--color-surface) 86%, transparent);
  }

  @media (min-width: 768px) {
    .featured-shell {
      padding: 1.5rem;
    }
  }

  .featured-image {
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card);
  }

  .featured-content {
    background: var(--color-surface);
    border-radius: var(--radius-hero);
    box-shadow: var(--shadow-card);
    overflow: hidden;
    padding: 1.5rem;
    transition:
      transform var(--duration-normal) var(--ease-out),
      box-shadow var(--duration-normal) var(--ease-out),
      border-color var(--duration-fast) var(--ease-out);
  }

  .featured-content:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
    border-color: var(--color-accent);
  }

  .featured-kicker {
    color: var(--color-accent);
    font-family: var(--font-sans);
    font-weight: 600;
    letter-spacing: 0.04em;
  }

  .featured-title {
    font-family: var(--font-display);
    color: var(--color-text);
    letter-spacing: -0.01em;
    line-height: 1.2;
  }

  .featured-title-link:hover .featured-title {
    color: var(--color-accent);
  }

  .featured-description,
  .featured-date {
    color: var(--color-text-muted);
  }
</style>
