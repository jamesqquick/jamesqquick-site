---
import { CollectionEntry } from "astro:content";
import Section from "./Section.astro";
import { Image } from "astro:assets";
import Link from "./Link.astro";
import SplitSection from "./SplitSection.astro";

export interface Props {
  image: CollectionEntry<"images">;
    title: string;
    description: string;
    href:string
    date: Date
    isLight?: boolean;
    hasYPadding?: boolean;
    classStr?: string;
}

const { image, title, description, href, date, isLight, hasYPadding = true, classStr } = Astro.props as Props;

---

<SplitSection isLight={isLight} hasYPadding={hasYPadding} classStr={classStr}>
    <a href={href} slot="left">
      <Image
        height={540}
        width={960}
        src={image}
        class="featured-image"
        alt={title}
      />
    </a>
    <div slot="right" class="featured-content" data-interactive>
      <p class="featured-kicker text-lg uppercase">Featured</p>
      <a href={href} class="featured-title-link">
        <h2 class="featured-title text-3xl font-bold mb-1">{title}</h2>
      </a>
      <p class="featured-description text-lg mb-4">
        {description}
      </p>
      <div class="flex justify-between items-center gap-4">
        <Link isFancy={true}  href={href}
          text="Read blog"/>
        <p class="featured-date text-lg">
          {date.toLocaleDateString("en-us", {
            year: "numeric",
            month: "short",
            day: "numeric",
          })}
        </p>
      </div>
    </div>
</SplitSection>

<style>
  .featured-image {
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card);
  }

  .featured-content {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card);
    padding: 1.5rem;
    transition:
      transform var(--duration-normal) var(--ease-out),
      box-shadow var(--duration-normal) var(--ease-out),
      border-color var(--duration-fast) var(--ease-out);
  }

  .featured-content:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
    border-color: var(--color-accent);
  }

  .featured-kicker {
    color: var(--color-accent);
    font-family: var(--font-sans);
    font-weight: 600;
    letter-spacing: 0.04em;
  }

  .featured-title {
    font-family: var(--font-display);
    color: var(--color-text);
    letter-spacing: -0.01em;
    line-height: 1.2;
  }

  .featured-title-link:hover .featured-title {
    color: var(--color-accent);
  }

  .featured-description,
  .featured-date {
    color: var(--color-text-muted);
  }
</style>
