---
import Section from "./Section.astro";
import { Image } from "astro:assets";
import SplitSection from "./SplitSection.astro";

export interface Props {
  image: any;
    title: string;
    description: string;
    href:string
    date: Date
    openInNewTab?: boolean;
    isLight?: boolean;
    hasYPadding?: boolean;
    classStr?: string;
}

const { image, title, description, href, date, openInNewTab = false, isLight, hasYPadding = true, classStr } = Astro.props as Props;

---

<SplitSection isLight={isLight} hasYPadding={hasYPadding} classStr={classStr}>
    <a href={href} slot="left" target={openInNewTab ? "_blank" : undefined} rel={openInNewTab ? "noopener noreferrer" : undefined}>
      <Image
        height={540}
        width={960}
        src={image}
        class="rounded-2xl"
        alt={title}
      />
    </a>
    <div slot="right">
      <p class="text-lg uppercase text-brand">Featured</p>
      <a href={href} target={openInNewTab ? "_blank" : undefined} rel={openInNewTab ? "noopener noreferrer" : undefined}>
        <h2 class="text-3xl font-bold mb-1">{title}</h2>
      </a>
      <p class="text-lg opacity-80 mb-4">
        {description}
      </p>
      <div class="flex justify-start">
        <p class="text-lg opacity-80">
          Last updated on {date.toLocaleDateString("en-us", {
            year: "numeric",
            month: "short",
            day: "numeric",
          })}
        </p>
      </div>
    </div>
</SplitSection>
