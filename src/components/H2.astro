---
interface Props {
  text: string;
  ariaLabel?: string;
  classStr?: string;
}
const { text, ariaLabel, classStr } = Astro.props;
---

<h2
  class={`heading-2 ${classStr || ""}`}
  aria-label={ariaLabel || text}
>
  {text}
</h2>

<style>
  .heading-2 {
    font-family: var(--font-display);
    color: var(--color-text);
    font-size: 1.875rem;
    line-height: 1.2;
    letter-spacing: -0.01em;
    font-weight: 700;
  }

  @media (min-width: 768px) {
    .heading-2 {
      font-size: 2.25rem;
    }
  }
</style>
