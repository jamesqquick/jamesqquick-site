---
import { Image } from "astro:assets";
import fedexLight from "../images/company-logos/fedex.png";
import fedexDark from "../images/company-logos/fedex-dark.png";
import microsoftLight from "../images/company-logos/microsoft.png";
import microsoftDark from "../images/company-logos/microsoft-dark.png";
import auth0Light from "../images/company-logos/auth0.png";
import auth0Dark from "../images/company-logos/auth0-dark.png";
import commerceWhite from "../images/company-logos/commerce-white.png";
import commerceBlack from "../images/company-logos/commerce-black.png";
import planetscaleLight from "../images/company-logos/planetscale.png";
import planetscaleDark from "../images/company-logos/planetscale-dark.png";
import Section from "./Section.astro";
import SectionHeader from "./SectionHeader.astro";

const title = "Work Experience";
const subtitle = "I've worked at some amazing companies";
---

<Section tone="elevated" paddingY="half">
  <SectionHeader title={title} subtitle={subtitle} variant="secondary"/>
  <div
    class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 items-end place-items-center gap-y-16 gap-x-8 max-x-xl mx-auto"
  >
    <div class="relative flex h-10 w-full max-w-[9rem] items-end justify-center">
      <Image
        class="work-exp-fedex work-exp-fedex--dark-theme h-10 w-auto max-w-full object-contain object-bottom"
        src={fedexLight}
        alt="FedEx logo"
        width={fedexLight.width}
        height={fedexLight.height}
        sizes="9rem"
      />
      <Image
        class="work-exp-fedex work-exp-fedex--light-theme h-10 w-auto max-w-full object-contain object-bottom"
        src={fedexDark}
        alt="FedEx logo"
        width={fedexDark.width}
        height={fedexDark.height}
        sizes="9rem"
      />
    </div>
    <div class="relative flex h-10 w-full max-w-[9rem] items-end justify-center">
      <Image
        class="work-exp-microsoft work-exp-microsoft--dark-theme h-10 w-auto max-w-full object-contain object-bottom"
        src={microsoftLight}
        alt="Microsoft logo"
        width={microsoftLight.width}
        height={microsoftLight.height}
        sizes="9rem"
      />
      <Image
        class="work-exp-microsoft work-exp-microsoft--light-theme h-10 w-auto max-w-full object-contain object-bottom"
        src={microsoftDark}
        alt="Microsoft logo"
        width={microsoftDark.width}
        height={microsoftDark.height}
        sizes="9rem"
      />
    </div>
    <div class="relative flex h-10 w-full max-w-[9rem] items-end justify-center">
      <Image
        class="work-exp-auth0 work-exp-auth0--dark-theme h-10 w-auto max-w-full object-contain object-bottom"
        src={auth0Light}
        alt="Auth0 logo"
        width={auth0Light.width}
        height={auth0Light.height}
        sizes="9rem"
      />
      <Image
        class="work-exp-auth0 work-exp-auth0--light-theme h-10 w-auto max-w-full object-contain object-bottom"
        src={auth0Dark}
        alt="Auth0 logo"
        width={auth0Dark.width}
        height={auth0Dark.height}
        sizes="9rem"
      />
    </div>
    <div class="relative flex h-10 w-full max-w-[9rem] items-end justify-center">
      <Image
        class="work-exp-planetscale work-exp-planetscale--dark-theme h-10 w-auto max-w-full object-contain object-bottom"
        src={planetscaleLight}
        alt="PlanetScale logo"
        width={planetscaleLight.width}
        height={planetscaleLight.height}
        sizes="9rem"
      />
      <Image
        class="work-exp-planetscale work-exp-planetscale--light-theme h-10 w-auto max-w-full object-contain object-bottom"
        src={planetscaleDark}
        alt="PlanetScale logo"
        width={planetscaleDark.width}
        height={planetscaleDark.height}
        sizes="9rem"
      />
    </div>
    <div class="relative flex h-10 w-full max-w-[11rem] items-end justify-center">
      <Image
        class="work-exp-commerce work-exp-commerce--dark h-10 w-auto max-w-full object-contain object-bottom"
        src={commerceWhite}
        alt="Commerce logo"
        width={commerceWhite.width}
        height={commerceWhite.height}
        sizes="11rem"
      />
      <Image
        class="work-exp-commerce work-exp-commerce--light h-10 w-auto max-w-full object-contain object-bottom"
        src={commerceBlack}
        alt="Commerce logo"
        width={commerceBlack.width}
        height={commerceBlack.height}
        sizes="11rem"
      />
    </div>
  </div>
</Section>

<style is:global>
  /* microsoft.png = light artwork for dark UI; microsoft-dark.png for light UI */
  .work-exp-microsoft--light-theme {
    display: none;
  }
  .work-exp-microsoft--dark-theme {
    display: block;
  }
  [data-theme="light"] .work-exp-microsoft--dark-theme {
    display: none;
  }
  [data-theme="light"] .work-exp-microsoft--light-theme {
    display: block;
  }

  /* Default matches site: dark theme — white logo on dark surface */
  .work-exp-commerce--light {
    display: none;
  }
  .work-exp-commerce--dark {
    display: block;
  }

  [data-theme="light"] .work-exp-commerce--dark {
    display: none;
  }
  [data-theme="light"] .work-exp-commerce--light {
    display: block;
  }

  /* auth0.png = light artwork for dark UI; auth0-dark.png = dark artwork for light UI */
  .work-exp-auth0--light-theme {
    display: none;
  }
  .work-exp-auth0--dark-theme {
    display: block;
  }
  [data-theme="light"] .work-exp-auth0--dark-theme {
    display: none;
  }
  [data-theme="light"] .work-exp-auth0--light-theme {
    display: block;
  }

  /* fedex.png / planetscale.png = light artwork for dark UI; *-dark.png for light UI */
  .work-exp-fedex--light-theme,
  .work-exp-planetscale--light-theme {
    display: none;
  }
  .work-exp-fedex--dark-theme,
  .work-exp-planetscale--dark-theme {
    display: block;
  }
  [data-theme="light"] .work-exp-fedex--dark-theme,
  [data-theme="light"] .work-exp-planetscale--dark-theme {
    display: none;
  }
  [data-theme="light"] .work-exp-fedex--light-theme,
  [data-theme="light"] .work-exp-planetscale--light-theme {
    display: block;
  }
</style>
