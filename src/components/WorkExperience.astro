---
import { Image } from "astro:assets";
import fedexLight from "../images/company-logos/fedex.png";
import fedexDark from "../images/company-logos/fedex-dark.png";
import microsoftLight from "../images/company-logos/microsoft.png";
import microsoftDark from "../images/company-logos/microsoft-dark.png";
import auth0Light from "../images/company-logos/auth0.png";
import auth0Dark from "../images/company-logos/auth0-dark.png";
import commerceWhite from "../images/company-logos/commerce-white.png";
import commerceBlack from "../images/company-logos/commerce-black.png";
import planetscaleLight from "../images/company-logos/planetscale.png";
import planetscaleDark from "../images/company-logos/planetscale-dark.png";
import cloudflareLight from "../images/company-logos/cloudflare.png";
import cloudflareDark from "../images/company-logos/cloudflare-dark.png";
import Section from "./Section.astro";
import SectionHeader from "./SectionHeader.astro";

const title = "Work Experience";
const subtitle = "I've worked at some amazing companies";

const companies = [
  {
    name: "Cloudflare",
    light: cloudflareLight,
    dark: cloudflareDark,
    classPrefix: "work-exp-cloudflare",
    maxWidth: "9rem",
  },
  {
    name: "FedEx",
    light: fedexLight,
    dark: fedexDark,
    classPrefix: "work-exp-fedex",
    maxWidth: "9rem",
  },
  {
    name: "Microsoft",
    light: microsoftLight,
    dark: microsoftDark,
    classPrefix: "work-exp-microsoft",
    maxWidth: "9rem",
  },
  {
    name: "Auth0",
    light: auth0Light,
    dark: auth0Dark,
    classPrefix: "work-exp-auth0",
    maxWidth: "9rem",
  },
  {
    name: "PlanetScale",
    light: planetscaleLight,
    dark: planetscaleDark,
    classPrefix: "work-exp-planetscale",
    maxWidth: "9rem",
  },
  {
    name: "Commerce",
    light: commerceWhite,
    dark: commerceBlack,
    classPrefix: "work-exp-commerce",
    maxWidth: "11rem",
  },
];
---

<Section tone="elevated" paddingY="half">
  <SectionHeader title={title} subtitle={subtitle} variant="secondary" />
  <div class="ticker-wrapper">
    <div class="ticker-track">
      {/* Render logos twice for seamless looping */}
      {[...companies, ...companies].map((company) => (
        <div
          class="ticker-item"
          style={`max-width: ${company.maxWidth}; min-width: ${company.maxWidth};`}
        >
          <Image
            class={`${company.classPrefix} ${company.classPrefix}--dark-theme h-10 w-auto max-w-full object-contain object-bottom`}
            src={company.light}
            alt={`${company.name} logo`}
            width={company.light.width}
            height={company.light.height}
            sizes={company.maxWidth}
          />
          <Image
            class={`${company.classPrefix} ${company.classPrefix}--light-theme h-10 w-auto max-w-full object-contain object-bottom`}
            src={company.dark}
            alt={`${company.name} logo`}
            width={company.dark.width}
            height={company.dark.height}
            sizes={company.maxWidth}
          />
        </div>
      ))}
    </div>
  </div>
</Section>

<style is:global>
  /* ---- Ticker layout ---- */
  .ticker-wrapper {
    overflow: hidden;
    width: 100%;
    mask-image: linear-gradient(
      to right,
      transparent,
      black 10%,
      black 90%,
      transparent
    );
    -webkit-mask-image: linear-gradient(
      to right,
      transparent,
      black 10%,
      black 90%,
      transparent
    );
  }

  .ticker-track {
    display: flex;
    align-items: center;
    gap: 4rem;
    width: max-content;
    animation: ticker-scroll 25s linear infinite;
  }

  .ticker-item {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 2.5rem;
  }

  @keyframes ticker-scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  /* Pause on hover for accessibility */
  .ticker-wrapper:hover .ticker-track {
    animation-play-state: paused;
  }

  /* Respect reduced motion preference */
  @media (prefers-reduced-motion: reduce) {
    .ticker-track {
      animation-play-state: paused;
    }
  }

  /* ---- Dark / light logo toggling ---- */
  .work-exp-cloudflare--light-theme,
  .work-exp-microsoft--light-theme,
  .work-exp-auth0--light-theme,
  .work-exp-fedex--light-theme,
  .work-exp-planetscale--light-theme,
  .work-exp-commerce--light-theme {
    display: none;
  }

  .work-exp-cloudflare--dark-theme,
  .work-exp-microsoft--dark-theme,
  .work-exp-auth0--dark-theme,
  .work-exp-fedex--dark-theme,
  .work-exp-planetscale--dark-theme,
  .work-exp-commerce--dark-theme {
    display: block;
  }

  [data-theme="light"] .work-exp-cloudflare--dark-theme,
  [data-theme="light"] .work-exp-microsoft--dark-theme,
  [data-theme="light"] .work-exp-auth0--dark-theme,
  [data-theme="light"] .work-exp-fedex--dark-theme,
  [data-theme="light"] .work-exp-planetscale--dark-theme,
  [data-theme="light"] .work-exp-commerce--dark-theme {
    display: none;
  }

  [data-theme="light"] .work-exp-cloudflare--light-theme,
  [data-theme="light"] .work-exp-microsoft--light-theme,
  [data-theme="light"] .work-exp-auth0--light-theme,
  [data-theme="light"] .work-exp-fedex--light-theme,
  [data-theme="light"] .work-exp-planetscale--light-theme,
  [data-theme="light"] .work-exp-commerce--light-theme {
    display: block;
  }
</style>
