---
import Section from "@components/Section.astro";
import FeaturedSplitSection from "@components/FeaturedSplitSection.astro";
import { getCourseCatalog, getCourseHostType, getCourseUrl } from "src/utils/contentCollections";
import SectionHeader from "@components/SectionHeader.astro";
import { Image } from "astro:assets";
import {
  COURSES_DESCRIPTION,
  COURSES_HERO_TITLE,
  COURSES_SUBTITLE,
} from "src/content/coursesMeta";

/** Public files under `public/` — use `<img>` so we do not depend on the Astro image pipeline for static URLs. */

export const prerender = true;

const courses = (await getCourseCatalog())
  .filter(
    (course) =>
      course.data.coverImage &&
      course.data.description &&
      (course.data.updatedDate ?? course.data.pubDate)
  )
  .slice(0, 4);
const featuredCourse = courses.splice(0, 1)[0];
---

<Section paddingY="spacious">
  <SectionHeader
    title={COURSES_HERO_TITLE}
    subtitle={COURSES_SUBTITLE}
    description={COURSES_DESCRIPTION}
    variant="secondary"
  />

  {
    featuredCourse && (
      <div class="mt-12 md:mt-14">
        <FeaturedSplitSection
          image={featuredCourse.data.coverImage!}
          title={featuredCourse.data.title}
          description={featuredCourse.data.description!}
          href={getCourseUrl(featuredCourse)}
          date={(featuredCourse.data.updatedDate ?? featuredCourse.data.pubDate)!}
          ctaText="View course"
          openInNewTab={getCourseHostType(featuredCourse) === "external"}
        />
      </div>
    )
  }

  <div class="mt-12 md:mt-14">
    <SectionHeader title="Other courses" />
    <div class="flex flex-col lg:flex-row justify-center gap-10">
      {
        courses.map((course) => (
          <div class="flex gap-x-8 lg:gap-x-2 items-center lg:justify-between">
            <Image
              height={128}
              width={128}
              format="webp"
              quality={80}
              src={course.data.coverImage!}
              alt={course.data.title}
              class="rounded-lg h-16 w-16 object-cover border border-border"
              loading="lazy"
            />
            <a
              href={getCourseUrl(course)}
              rel="noopener noreferrer"
              target={getCourseHostType(course) === "external" ? "_blank" : undefined}
            >
              <h4 class="w-52">{course.data.title}</h4>
            </a>
          </div>
        ))
      }
    </div>
  </div>
</Section>
