---
/** Two-column grid layout only. Compose with `Section` when you need tone or vertical padding. */
export interface Props {
  classStr?: string;
  contentClassStr?: string;
}

const { classStr, contentClassStr } = Astro.props as Props;
---

<div
  class:list={[
    "grid grid-cols-1 md:grid-cols-2 gap-8 items-center",
    contentClassStr,
    classStr,
  ]}
>
  <div>
    <slot name="left" />
  </div>
  <div>
    <slot name="right" />
  </div>
</div>
