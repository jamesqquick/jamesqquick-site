---

interface Props {
  size?: "small" | "medium" | "large";
  border?: 'accent' | 'accentSubtle';
  classStr?: string;
  fill?: 'accent' | 'accentSubtle';
}

const { size = "medium", border = "accent", classStr, fill } = Astro.props;

const sizeClasses = {
  small: "w-24 h-24",
  medium: "w-32 h-32",
  large: "w-40 h-40"
};
const borderClasses = {
  accent: "border border-accent",
  accentSubtle: "border border-accent-subtle",
};

const fillClasses = {
  accent: "bg-accent",
  accentSubtle: "bg-accent-subtle",
};
---
<div class={`border ${borderClasses[border]} rounded-3xl opacity-50  ${sizeClasses[size]} ${fill && fillClasses[fill] } ${classStr}`} />