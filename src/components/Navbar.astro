---
import { Icon } from "astro-icon/components";
import Logo from "../images/logo.astro";
import Section from "./Section.astro";
---

<Section hasYPadding={false}>
  <nav class="navbar-shell flex flex-row gap-5 justify-between items-center sm:items-center z-10 h-[100px] bg-transparent relative">
    <a
      href="/"
      class="nav-link"
      aria-label="home page"
    >
      <!-- <NameLogo /> -->
      <Logo classStr="fill-current h-12 w-12" />
    </a>
    <div class="hidden md:flex items-center gap-6 text-lg">
      <a href="/about/" class="nav-link transition-colors">About</a>
      <a href="/blog/" class="nav-link transition-colors">Blog</a>
      <a href="/speaking/" class="nav-link transition-colors">Speaking</a>
      <a href="/courses/" class="nav-link transition-colors">Courses</a>
      <a href="/uses" class="nav-link transition-colors">Uses</a>
      <button id="themeToggleDesktop" aria-label="toggle theme" class="theme-toggle">
        <Icon class="inline h-6 w-6" name="mdi:theme-light-dark" />
      </button>
    </div>
    <button
      id="hamburger"
      aria-label="menu"
      aria-controls="mobileMenu"
      class="md:hidden nav-link cursor-pointer"
    >
      <Icon
        class="inline  h-10 w-10 "
        name="mdi:menu"
      />
    </button>
    <div
      id="mobileMenu"
      class="fixed md:hidden items-center justify-center md:relative inset-0 bg-bg md:bg-transparent hidden py-5 overflow-auto z-10"
    >
      <div
        class="flex flex-col md:flex-row gap-10 md:gap-5 font-light text-center md:text-left text-2xl md:text-xl relative pt-10"
      >
        <button id="close" class="nav-link">
          <Icon
            class="inline absolute top-4 right-4 md:hidden h-10 w-10 cursor-pointer "
            name="mdi:close"
          />
        </button>
        <a href="/about/" class="nav-link transition-colors">About</a>
        <a href="/blog/" class="nav-link transition-colors">Blog</a>
        <a href="/speaking/" class="nav-link transition-colors">Speaking</a>
        <a href="/courses/" class="nav-link transition-colors">Courses</a>
        <a href="/uses" class="nav-link transition-colors">Uses</a>
        <button id="themeToggleMobile" aria-label="toggle theme" class="theme-toggle md:hidden">
          <Icon class="inline h-8 w-8" name="mdi:theme-light-dark" />
        </button>
      </div>
    </div>
  </nav>
</Section>

<style>
  .navbar-shell {
    color: var(--color-text);
  }

  .nav-link {
    color: inherit;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .nav-link:hover {
    color: var(--color-accent);
  }

  .nav-link:focus-visible,
  .theme-toggle:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
    border-radius: 8px;
  }

  .theme-toggle {
    color: var(--color-text);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-button);
    padding: 0.5rem;
    transition:
      color var(--duration-fast) var(--ease-out),
      border-color var(--duration-fast) var(--ease-out),
      background-color var(--duration-fast) var(--ease-out);
  }

  .theme-toggle:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
    background: var(--color-accent-subtle);
  }
</style>

<script>
  document.addEventListener("click", (e) => {
    const target = e.target;
    if (!(target instanceof Element)) return;

    if (target.closest("#hamburger")) {
      const mobileMenu = document.getElementById("mobileMenu");
      mobileMenu?.classList.remove("hidden");
      document.body.dataset.menuOpen = "true";
      return;
    }

    if (target.closest("#close")) {
      const mobileMenu = document.getElementById("mobileMenu");
      mobileMenu?.classList.add("hidden");
      delete document.body.dataset.menuOpen;
    }
  });
</script>
