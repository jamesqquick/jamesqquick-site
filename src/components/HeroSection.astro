---
import Section from "./Section.astro";
import Rectangle from "./Rectangle.astro";
import H1 from "./H1.astro";

export interface Props {
  title: string;
  subtitle: string;
  description?: string;
  hasFullHeight?: boolean;
  h1AriaLabel?: string;
}

const {
  title,
  subtitle,
  description,
  hasFullHeight = true,
  h1AriaLabel = "James Q Quick - developer, speaker, and teacher."
} = Astro.props as Props;

---

<Section hasYPadding={false} >
  <div
    class={`hero-shell py-20 flex items-center ${
      hasFullHeight ? "lg:h-[calc(100vh-240px)] lg:py-0" : "md:py-32 lg:py-40"
    } `}
  >
    <div class="max-w-xl">
      <div class="mb-2">
        <p class="hero-kicker text-2xl md:text-3xl">{title}</p>
        <H1
          text={subtitle}
          ariaLabel={h1AriaLabel}
        />
      </div>
      {description && <p class="hero-description text-lg">{description}</p>}
    </div>
    <Rectangle size="medium" border="lightBrand" classStr="hidden md:block absolute -right-10 top-[200px] " />
    <Rectangle size="medium" border="brand" classStr="hidden md:block absolute right-10 top-[280px]"  />
</div>

<style>
  .hero-shell {
    position: relative;
  }

  .hero-shell::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(700px 220px at 15% 15%, var(--color-accent-subtle), transparent 70%);
    pointer-events: none;
  }

  .hero-kicker {
    color: var(--color-accent);
    font-family: var(--font-display);
    font-weight: 600;
    letter-spacing: -0.01em;
  }

  .hero-description {
    color: var(--color-text-muted);
    max-width: 42rem;
    line-height: 1.56;
  }
</style>
