---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Testimonials from "../../components/Testimonials.astro";
import SpeakerFormCallout from "../../components/SpeakerFormCallout.astro";
import SpeakingHero from "../../components/speaking/SpeakingHero.astro";
import SpeakingStats from "../../components/speaking/SpeakingStats.astro";
import SpeakingTopics from "../../components/speaking/SpeakingTopics.astro";
import SpeakingFeaturedTalk from "../../components/speaking/SpeakingFeaturedTalk.astro";
import SpeakingAbout from "../../components/speaking/SpeakingAbout.astro";
import SpeakingGallery from "../../components/speaking/SpeakingGallery.astro";
import SpeakingEventCta from "../../components/speaking/SpeakingEventCta.astro";
import {
  speakingHero,
  speakingStats,
  speakingTopics,
  featuredTalk,
  speakingAbout,
  speakingGallery,
  eventCta,
  speakerKitLinks,
} from "../../data/speakingPage";

export const prerender = true;
---

<BaseLayout>
  <SpeakingHero {...speakingHero} />
  <SpeakingStats stats={speakingStats} />
  <SpeakingTopics topics={speakingTopics} />
  <SpeakingFeaturedTalk {...featuredTalk} />
  <SpeakingAbout {...speakingAbout} />
  <Testimonials />
  <SpeakingGallery items={speakingGallery} />
  <SpeakingEventCta {...eventCta} />
  <div id="speakerForm">
    <SpeakerFormCallout kitLinks={speakerKitLinks} />
  </div>
</BaseLayout>