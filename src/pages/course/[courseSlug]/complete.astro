---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Section from "../../../components/Section.astro";
import { getCourseBySlug, getInternalCourses } from "src/utils/contentCollections";

export const prerender = true;

export async function getStaticPaths() {
  const courses = await getInternalCourses();
  return courses.map((course) => ({
    params: { courseSlug: course.data.slug ?? course.id.split("/")[0] },
  }));
}

const courseSlug = Astro.params.courseSlug!;
const course = await getCourseBySlug(courseSlug);
if (!course) {
  return Astro.redirect("/courses");
}
---

<BaseLayout title={`${course.data.title} | Complete`}>
  <main>
    <Section classStr="pt-16 pb-24">
      <div class="max-w-2xl mx-auto text-center space-y-6">
        <h1 class="text-4xl font-bold">Course Complete</h1>
        <p class="text-gray-300">Great work finishing {course.data.title}.</p>
        <canvas id="fireworks" class="fixed inset-0 pointer-events-none"></canvas>
        <div class="border border-gray-700 rounded-xl p-6 bg-gray-900/40">
          <p class="text-sm text-gray-400">Certificate</p>
          <p id="cert-course" class="text-xl font-semibold mt-2">{course.data.title}</p>
          <p id="cert-date" class="text-sm text-gray-300 mt-2"></p>
          <p id="cert-id" class="text-xs text-gray-400 mt-3"></p>
        </div>
        <div class="flex gap-3 justify-center">
          <a href="/courses">Browse More Courses</a>
          <a href={`/course/${courseSlug}`}>Back to Course</a>
        </div>
      </div>
    </Section>
  </main>
</BaseLayout>

<script define:vars={{ courseSlug, courseTitle: course.data.title }}>
  const progress = JSON.parse(localStorage.getItem("progress") || "{}");
  const certificates = JSON.parse(localStorage.getItem("certificates") || "{}");
  const lessonIds = Object.keys(progress).filter((id) =>
    id.startsWith(`${courseSlug}/sections/`)
  );
  const allComplete = lessonIds.length > 0 && lessonIds.every((id) => progress[id]);
  if (!allComplete) {
    window.location.href = `/course/${courseSlug}`;
  }

  if (!certificates[courseSlug]) {
    certificates[courseSlug] = {
      id: `${courseSlug}-${Date.now().toString(36)}`,
      courseName: courseTitle,
      completedAt: new Date().toISOString(),
    };
    localStorage.setItem("certificates", JSON.stringify(certificates));
  }

  const cert = certificates[courseSlug];
  const dateEl = document.getElementById("cert-date");
  const idEl = document.getElementById("cert-id");
  if (dateEl) dateEl.textContent = `Completed on ${new Date(cert.completedAt).toLocaleDateString()}`;
  if (idEl) idEl.textContent = `Certificate ID: ${cert.id}`;

  const canvas = document.getElementById("fireworks");
  if (!(canvas instanceof HTMLCanvasElement)) return;
  const ctx = canvas.getContext("2d");
  if (!ctx) return;
  const resize = () => {
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
  };
  resize();
  window.addEventListener("resize", resize);
  const particles = [];
  const colors = ["#f97316", "#fbbf24", "#22c55e", "#3b82f6", "#a855f7", "#ec4899", "#ffffff"];
  for (let burst = 0; burst < 8; burst++) {
    const x = Math.random() * canvas.width;
    const y = Math.random() * (canvas.height * 0.5);
    const count = 40 + Math.floor(Math.random() * 30);
    for (let i = 0; i < count; i++) {
      const angle = (Math.PI * 2 * i) / count;
      const speed = 1 + Math.random() * 4;
      particles.push({
        x,
        y,
        vx: Math.cos(angle) * speed,
        vy: Math.sin(angle) * speed,
        alpha: 1,
        color: colors[Math.floor(Math.random() * colors.length)],
      });
    }
  }
  const tick = () => {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    for (const p of particles) {
      if (p.alpha <= 0) continue;
      p.x += p.vx;
      p.y += p.vy;
      p.vy += 0.03;
      p.alpha -= 0.01;
      ctx.globalAlpha = Math.max(0, p.alpha);
      ctx.fillStyle = p.color;
      ctx.fillRect(p.x, p.y, 2, 2);
    }
    ctx.globalAlpha = 1;
    if (particles.some((p) => p.alpha > 0)) requestAnimationFrame(tick);
  };
  tick();
</script>
